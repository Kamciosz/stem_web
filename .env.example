# Public URL used by server redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for admin session gate
ADMIN_PANEL_TOKEN=change-me-strong-token

# ============================================
# Supabase — baza pytań do quizów
# ============================================
# URL projektu (Settings → API → Project URL)
# Przykład: https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Klucz anon / publishable — bezpieczny w przeglądarce (tylko odczyt z RLS).
# W przeglądarce NIE da się z niego wyciągnąć poprawnych odpowiedzi
# (są w chronionej kolumnie, a RLS blokuje SELECT do niej z roli anon).
# Przykład: sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME

# Klucz service role / secret — TYLKO po stronie serwera (route handlers).
# NIGDY nie importuj tego w plikach z "use client".
# Używany do: losowania puli pytań, walidacji odpowiedzi, zapisu attemptów.
# Przykład: sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME
